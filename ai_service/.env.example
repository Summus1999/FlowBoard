# ==========================================
# FlowBoard AI Service 环境变量配置示例
# ==========================================

# 应用配置
DEBUG=false
ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flowboard_ai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis配置
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=your_redis_password

# LangSmith配置（可选）
# LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=flowboard-ai
LANGSMITH_TRACING=true

# Qwen配置（阿里通义千问）
# QWEN_API_KEY=your_qwen_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
QWEN_DEFAULT_MODEL=qwen-max
QWEN_EMBEDDING_MODEL=text-embedding-v3

# Kimi配置（Moonshot）
# KIMI_API_KEY=your_kimi_api_key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_DEFAULT_MODEL=moonshot-v1-8k

# GLM配置（智谱AI）
# GLM_API_KEY=your_glm_api_key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_DEFAULT_MODEL=glm-4-flash

# 模型路由配置
DEFAULT_MODEL_PROVIDER=qwen
FALLBACK_MODEL_PROVIDER=kimi

# 预算配置（RMB/月）
MONTHLY_BUDGET_RMB=150.0
COST_WARNING_THRESHOLD=0.8

# 安全配置
SECRET_KEY=change-me-in-production

# 文档配置
DOCS_BASE_PATH=./docs
