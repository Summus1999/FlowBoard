# ==========================================
# FlowBoard AI Service - Environment Config
# Lightweight local mode (SQLite + ChromaDB)
# ==========================================

# App
DEBUG=false
ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# Local data directory (SQLite DB + ChromaDB persistence)
# DATA_DIR=./local_data

# LangSmith (optional)
# LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=flowboard-ai
LANGSMITH_TRACING=false

# Qwen (Alibaba)
# QWEN_API_KEY=your_qwen_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
QWEN_DEFAULT_MODEL=qwen-max
QWEN_EMBEDDING_MODEL=text-embedding-v3

# Kimi (Moonshot)
# KIMI_API_KEY=your_kimi_api_key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_DEFAULT_MODEL=moonshot-v1-8k

# GLM (Zhipu AI)
# GLM_API_KEY=your_glm_api_key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_DEFAULT_MODEL=glm-4-flash

# Model routing
DEFAULT_MODEL_PROVIDER=qwen
FALLBACK_MODEL_PROVIDER=kimi

# Budget (RMB/month)
MONTHLY_BUDGET_RMB=150.0
COST_WARNING_THRESHOLD=0.8

# Security
SECRET_KEY=change-me-in-production
# API_TOKEN: required for remote access; leave empty for local-only
# API_TOKEN=your_secure_random_token

# Docs
DOCS_BASE_PATH=./docs
