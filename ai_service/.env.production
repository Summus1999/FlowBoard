# ==========================================
# FlowBoard AI Service - Production Config
# ==========================================

# App
DEBUG=false
ENV=production
API_HOST=0.0.0.0
API_PORT=8000

# API Token (Electron client must send this in Authorization header)
# IMPORTANT: Change this to your own token!
API_TOKEN=CHANGE_ME_TO_A_SECURE_RANDOM_STRING

# Database (overridden by docker-compose, but kept as fallback)
DATABASE_URL=postgresql://flowboard:flowboard_secret_2026@postgres:5432/flowboard_ai
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# Redis
REDIS_URL=redis://:flowboard_redis_2026@redis:6379/0

# Docker Compose DB credentials
POSTGRES_USER=flowboard
POSTGRES_PASSWORD=flowboard_secret_2026
POSTGRES_DB=flowboard_ai
REDIS_PASSWORD=flowboard_redis_2026

# CORS (allow all origins for Electron app)
CORS_ORIGINS=["*"]

# Model API Keys (leave empty, will be configured from Electron UI)
# QWEN_API_KEY=
# KIMI_API_KEY=
# GLM_API_KEY=

# Model routing
DEFAULT_MODEL_PROVIDER=qwen
FALLBACK_MODEL_PROVIDER=kimi

# Budget
MONTHLY_BUDGET_RMB=150.0
COST_WARNING_THRESHOLD=0.8

# Security
SECRET_KEY=CHANGE_ME_TO_A_SECURE_RANDOM_STRING

# LangSmith (optional)
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=
